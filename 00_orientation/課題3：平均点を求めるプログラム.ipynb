     "text": [
      "10人のテストの平均点は73.4です\n"
     ]
    }
   ],
   "source": [
    "Amnt = 0\n",
    "Cnt = 0\n",
    "while True:\n",
    "    score = int(input(\"点数を入力してください：\"))\n",
    "    if score >= 0:\n",
    "        Amnt = Amnt + score\n",
    "        Cnt += 1\n",
    "    if score == -1:\n",
    "        avg = round(Amnt / Cnt,1)\n",
    "        break\n",
    "print(f\"{Cnt}人のテストの平均点は{avg}です\")"
   ]
  }
 ],
